generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  DISCORD
}

enum Role {
  ADMIN
  USER
}

enum EmailCodeProps {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum ChatRole {
  USER
  ASSISTANT
}

enum ChatMode {
  CREATIVE     
  BALANCED   
  STRICT     
}

enum ArticleStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum ArticleCategory {
  PREMIUM_COLLECTION
  BEST_MINIMALS
  CRAZY_SHOES
  NEW_SHOES
  MY_BLOG
  USERS_ARTICLES
}

enum StatusChat {
  OPEN
  CLOSED
}

enum MissionStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ReactionType {
  LIKE
  DISLIKE
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  password           String?
  isVerified         Boolean             @default(false)
  role               Role                @default(USER)
  createdAt          DateTime            @default(now())
  passwordResetTokens PasswordResetToken[]
  emailCodes          EmailCode[]
  chatSession         ChatSession[]
  articles            Article[]
  supportChats        SupportChat[]
  googleId            String? @unique
  githubId            String? @unique
  discordId           String? @unique
  comments            Comment[]
  commentReactions    CommentReaction[]
  provider            AuthProvider @default(LOCAL)
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
}

model EmailCode {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  EmailCodeProps  EmailCodeProps @default(VERIFY_EMAIL)
  expiresAt DateTime
  used      Boolean  @default(false)
  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String? 
  imageUrl  String?    
  createdAt DateTime @default(now())
}

model ChatSession {
  title     String  @default("New chat")
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  mode      ChatMode
  createdAt DateTime @default(now())
  messages  ChatMessage[]
}

model Article {
  id               String          @id @default(uuid())
  title            String
  slug             String          @unique
  shortDescription String
  content          String          @db.Text
  coverImage       String          
  images           String[]       
  
  category         ArticleCategory
  status           ArticleStatus   @default(PENDING)
  
  views            Int             @default(0)
  tags             String[]       
  
  authorId         String
  author           User            @relation(fields: [authorId], references: [id])
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  publishedAt      DateTime?  

  comments        Comment[]
  @@index([category])        
  @@index([status])        
  @@index([authorId])       
}

model SupportChat {
  id      String          @id @default(uuid())
  userId  String
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      StatusChat  @default(OPEN)
  messages     SupportMessage[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
}

model SupportMessage{
  id       String          @id @default(uuid())
  chatId   String
  chat     SupportChat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderRole Role
  content   String
  createdAt DateTime    @default(now())
}

model Mission {
  id        String        @id @default(uuid())
  title     String
  status    MissionStatus @default(TODO)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Comment {
  id          String     @id @default(uuid())
  content     String
  createdAt   DateTime  @default(now())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  articleId   String
  article     Article   @relation(fields: [articleId], references: [id])
  reaction    CommentReaction[]
}

model CommentReaction {
  id          String    @id @default(ulid())
  type        ReactionType
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  commentId   String
  comment     Comment  @relation(fields: [commentId], references: [id])
  @@unique([userId, commentId])
}