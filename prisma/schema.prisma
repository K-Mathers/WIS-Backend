generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  DISCORD
}

enum Role {
  ADMIN
  USER
}

enum EmailCodeProps {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum ChatRole {
  USER
  ASSISTANT
}

enum ChatMode {
  CREATIVE
  BALANCED
  STRICT
}

enum ArticleStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
}

enum ArticleCategory {
  PREMIUM_COLLECTION
  BEST_MINIMALS
  CRAZY_SHOES
  NEW_SHOES
  MY_BLOG
  USERS_ARTICLES
}

enum StatusChat {
  OPEN
  CLOSED
}

enum MissionStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum Gender {
  MALE
  FEMALE
  UNISEX
  KIDS
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String?
  isVerified          Boolean              @default(false)
  role                Role                 @default(USER)
  createdAt           DateTime             @default(now())
  passwordResetTokens PasswordResetToken[]
  emailCodes          EmailCode[]
  chatSession         ChatSession[]
  articles            Article[]
  supportChats        SupportChat[]
  googleId            String?              @unique
  githubId            String?              @unique
  discordId           String?              @unique
  comments            Comment[]
  commentReactions    CommentReaction[]
  provider            AuthProvider         @default(LOCAL)
  cart                Cart?
  favorites           Favorite[]
  orders              Order[]
  reviews             Review[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
}

model EmailCode {
  id             String         @id @default(uuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash       String
  EmailCodeProps EmailCodeProps @default(VERIFY_EMAIL)
  expiresAt      DateTime
  used           Boolean        @default(false)

  @@index([userId])
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String?
  imageUrl  String?
  createdAt DateTime    @default(now())
}

model ChatSession {
  title     String        @default("New chat")
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  mode      ChatMode
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model Article {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique
  shortDescription String
  content          String   @db.Text
  coverImage       String
  images           String[]

  category ArticleCategory
  status   ArticleStatus   @default(PENDING)

  views Int      @default(0)
  tags  String[]

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  comments Comment[]

  @@index([category])
  @@index([status])
  @@index([authorId])
}

model SupportChat {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    StatusChat       @default(OPEN)
  messages  SupportMessage[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model SupportMessage {
  id         String      @id @default(uuid())
  chatId     String
  chat       SupportChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderRole Role
  content    String
  createdAt  DateTime    @default(now())
}

model Mission {
  id        String        @id @default(uuid())
  title     String
  status    MissionStatus @default(TODO)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Comment {
  id        String            @id @default(uuid())
  content   String
  createdAt DateTime          @default(now())
  userId    String
  user      User              @relation(fields: [userId], references: [id])
  articleId String
  article   Article           @relation(fields: [articleId], references: [id])
  reaction  CommentReaction[]
}

model CommentReaction {
  id        String       @id @default(ulid())
  type      ReactionType
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  commentId String
  comment   Comment      @relation(fields: [commentId], references: [id])

  @@unique([userId, commentId])
}

model Product {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  description String            @db.Text
  gender      Gender
  sport       String?
  tags        String[]
  category    Category?         @relation(fields: [categoryId], references: [id])
  categoryId  String?
  colorways   ProductColorway[]
  reviews     Review[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model ProductColorway {
  id              String       @id @default(uuid())
  productId       String
  product         Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  color           String
  hexCode         String
  price           Decimal
  originalPrice   Decimal?
  discountPercent Int?
  images          String[]
  isNewRelease    Boolean      @default(false)
  skus            ProductSku[]
  cartItems       CartItem[]
  favorites       Favorite[]
  orderItems      OrderItem[]
}

model ProductSku {
  id         String          @id @default(uuid())
  colorwayId String
  colorway   ProductColorway @relation(fields: [colorwayId], references: [id], onDelete: Cascade)
  size       String
  stock      Int             @default(0)
}

model Cart {
  id     String     @id @default(uuid())
  userId String     @unique
  user   User       @relation(fields: [userId], references: [id])
  items  CartItem[]
}

model CartItem {
  id         String          @id @default(uuid())
  cartId     String
  cart       Cart            @relation(fields: [cartId], references: [id])
  colorwayId String
  colorway   ProductColorway @relation(fields: [colorwayId], references: [id])
  size       String
  quantity   Int             @default(1)
}

model Favorite {
  id         String          @id @default(uuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  colorwayId String
  colorway   ProductColorway @relation(fields: [colorwayId], references: [id])

  @@unique([userId, colorwayId])
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  products Product[]
}

model Review {
  id        String   @id @default(uuid())
  rating    Int      @default(5)
  comment   String?  @db.Text
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(PENDING)
  totalAmount Decimal
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model OrderItem {
  id         String          @id @default(uuid())
  orderId    String
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  colorwayId String
  colorway   ProductColorway @relation(fields: [colorwayId], references: [id])
  size       String
  quantity   Int
  price      Decimal
}
